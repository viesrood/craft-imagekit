{# Read-only overview of the ImageKit configuration. #}
{% import "_includes/forms.twig" as forms %}

<p>
    The ImageKit credentials are read from environment variables (or from
    <code>config/imagekit.php</code>). Add to your <code>.env</code>:
</p>

<pre>IMAGEKIT_PUBLIC_KEY=public_...
IMAGEKIT_PRIVATE_KEY=private_...
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/&lt;imagekit_id&gt;</pre>

{{ forms.autosuggestField({
    label: 'Public key',
    id: 'publicKey',
    name: 'settings[publicKey]',
    suggestEnvVars: true,
    value: settings.publicKey,
}) }}

{{ forms.autosuggestField({
    label: 'Private key',
    id: 'privateKey',
    name: 'settings[privateKey]',
    suggestEnvVars: true,
    value: settings.privateKey,
}) }}

{{ forms.autosuggestField({
    label: 'URL endpoint',
    id: 'urlEndpoint',
    name: 'settings[urlEndpoint]',
    suggestEnvVars: true,
    value: settings.urlEndpoint,
}) }}

{{ forms.selectField({
    label: 'Default format',
    id: 'defaultFormat',
    name: 'settings[defaultFormat]',
    options: [
        { label: 'Auto (WebP/AVIF)', value: 'auto' },
        { label: 'WebP', value: 'webp' },
        { label: 'AVIF', value: 'avif' },
        { label: 'JPG', value: 'jpg' },
        { label: 'PNG', value: 'png' },
        { label: 'None', value: '' },
    ],
    value: settings.defaultFormat,
}) }}

{{ forms.textField({
    label: 'Default quality (1-100)',
    id: 'defaultQuality',
    name: 'settings[defaultQuality]',
    type: 'number',
    size: 4,
    value: settings.defaultQuality,
}) }}

{{ forms.lightswitchField({
    label: 'Sign URLs by default',
    instructions: 'Recommended when a Web Proxy origin is enabled: an unsigned web proxy lets anyone transform arbitrary URLs on your account.',
    id: 'signUrls',
    name: 'settings[signUrls]',
    on: settings.signUrls,
}) }}

{{ forms.textField({
    label: 'Signed URL expiry (seconds)',
    instructions: 'Validity period for signed URLs; 0 = non-expiring.',
    id: 'signedExpire',
    name: 'settings[signedExpire]',
    type: 'number',
    size: 8,
    value: settings.signedExpire,
}) }}

{{ forms.textField({
    label: 'Default srcset widths',
    instructions: 'Comma-separated widths used by `imagekit_srcset()` and `imagekit_img()` when no explicit widths are given.',
    id: 'defaultSrcsetWidths',
    name: 'settings[defaultSrcsetWidths]',
    value: settings.defaultSrcsetWidths | join(', '),
}) }}

{{ forms.lightswitchField({
    label: 'Native asset URLs in devMode',
    instructions: 'Serve untransformed asset URLs for Craft assets while devMode is on. Useful when the local origin (e.g. *.ddev.site) is not reachable for ImageKit.',
    id: 'useNativeInDevMode',
    name: 'settings[useNativeInDevMode]',
    on: settings.useNativeInDevMode,
}) }}

{{ forms.textField({
    label: 'Upload folder (Media Library)',
    id: 'uploadFolder',
    name: 'settings[uploadFolder]',
    value: settings.uploadFolder,
}) }}
